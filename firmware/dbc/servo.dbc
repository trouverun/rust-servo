BA_ "GenMsgCycleTimeUs" BO_ 288 1000;
BA_ "GenMsgCycleTimeUs" BO_ 304 100000;
BA_ "GenMsgCycleTimeUs" BO_ 320 100000;

VAL_ 528 requested_mode 0 "Idle" 1 "Calibration" 2 "TorqueControl" 3 "CancelCalibration" 4 "FaultClear" ;
VAL_ 624 block_id 0 "protection_limits" 1 "motor_config" 2 "calibration_targets" 3 "current_gains_d" 4 "current_gains_q" 5 "motor_parameters" 6 "safe_stop_config" 255 "all" ;
